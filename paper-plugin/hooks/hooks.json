{
  "hooks": {
    "PostToolUse": [
      {
        "name": "markup-design-check",
        "matcher": "Write|Edit",
        "file_pattern": "**/*.{html,xml,jsx,tsx,vue,svelte}",
        "hooks": [
          {
            "type": "suggestion",
            "message": "[Paper] Markup modified — check: semantic tags, alt text on images, form label associations."
          }
        ]
      },
      {
        "name": "style-design-check",
        "matcher": "Write|Edit",
        "file_pattern": "**/*.{css,scss,sass,less}",
        "hooks": [
          {
            "type": "suggestion",
            "message": "[Paper] Stylesheet modified — check: contrast >= 4.5:1, rem/em units, focus styles."
          }
        ]
      }
    ]
  }
}
