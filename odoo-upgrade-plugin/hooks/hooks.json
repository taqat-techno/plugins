{
  "description": "Odoo upgrade hooks - core file protection",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/guard_core_odoo.py\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
