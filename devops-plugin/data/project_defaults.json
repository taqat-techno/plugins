{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$comment": "Azure DevOps projects configuration. Edit with your organization and project names.",
  "version": "1.0.0",
  "organization": "YOUR-ORG",
  "organizationUrl": "https://dev.azure.com/YOUR-ORG",
  "lastUpdated": "configure-me",

  "projects": [
    {
      "name": "Project Alpha",
      "id": null,
      "description": "Primary project  -  replace with your project description",
      "aliases": ["alpha", "project-alpha", "pa"],
      "defaultTeam": "Project Alpha Team",
      "primaryRepo": "project-alpha",
      "urlPath": "Project%20Alpha",
      "active": true,
      "priority": 1
    },
    {
      "name": "Project Beta",
      "id": null,
      "description": "Secondary project  -  replace with your project description",
      "aliases": ["beta", "project-beta", "pb"],
      "defaultTeam": "Project Beta Team",
      "primaryRepo": "project-beta",
      "urlPath": "Project%20Beta",
      "active": true,
      "priority": 2
    },
    {
      "name": "Project Gamma",
      "id": null,
      "description": "Third project  -  replace with your project description",
      "aliases": ["gamma", "project-gamma", "pg"],
      "defaultTeam": "Project Gamma Team",
      "primaryRepo": "project-gamma",
      "urlPath": "Project%20Gamma",
      "active": true,
      "priority": 3
    }
  ],

  "contextRules": {
    "persistence": {
      "description": "Context persists throughout conversation session",
      "resetOn": "explicit_switch_or_new_session"
    },
    "detection": {
      "method": "user_activity_analysis",
      "fallback": "ask_user",
      "confirmSelection": true
    },
    "override": {
      "temporary": {
        "triggers": ["in", "for", "from"],
        "behavior": "one_time_query_only"
      },
      "permanent": {
        "triggers": ["switch to", "use", "work on", "change project to", "set project"],
        "behavior": "update_default_context"
      }
    },
    "multiProject": {
      "triggers": ["all projects", "across all projects", "every project", "all my work"],
      "behavior": "query_all_aggregate_results"
    }
  },

  "switchPhrases": {
    "permanent": [
      "switch to {project}",
      "use {project}",
      "work on {project}",
      "change project to {project}",
      "set project {project}",
      "default project {project}"
    ],
    "temporary": [
      "in {project}",
      "for {project}",
      "from {project}",
      "{query} in {project}"
    ],
    "multiProject": [
      "all projects",
      "across all projects",
      "every project",
      "all my work"
    ],
    "queryContext": [
      "what project am I in",
      "current project",
      "which project",
      "show context"
    ]
  },

  "outputFormat": {
    "contextIndicator": " Project: {projectName}",
    "tempOverride": " Querying: {tempProject} (one-time)\n Default: {defaultProject}",
    "multiProject": " Querying all projects...",
    "switchConfirm": "? Switched to {newProject}\n\nPrevious: {oldProject}\nCurrent: {newProject}"
  },

  "urlTemplates": {
    "workItem": "https://dev.azure.com/YOUR-ORG/{projectUrlPath}/_workitems/edit/{workItemId}",
    "board": "https://dev.azure.com/YOUR-ORG/{projectUrlPath}/_boards/board",
    "backlog": "https://dev.azure.com/YOUR-ORG/{projectUrlPath}/_backlogs/backlog",
    "sprint": "https://dev.azure.com/YOUR-ORG/{projectUrlPath}/_sprints/taskboard",
    "repo": "https://dev.azure.com/YOUR-ORG/{projectUrlPath}/_git/{repoName}",
    "pr": "https://dev.azure.com/YOUR-ORG/{projectUrlPath}/_git/{repoName}/pullrequest/{prId}",
    "pipeline": "https://dev.azure.com/YOUR-ORG/{projectUrlPath}/_build?definitionId={pipelineId}",
    "wiki": "https://dev.azure.com/YOUR-ORG/{projectUrlPath}/_wiki/wikis"
  },

  "aliasResolution": {
    "description": "Resolve common aliases to project names",
    "caseSensitive": false,
    "matchPartial": true,
    "examples": {
      "alpha": "Project Alpha",
      "beta": "Project Beta",
      "gamma": "Project Gamma"
    }
  }
}
