{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$comment": "Azure DevOps projects configuration. Run /init profile to auto-populate from your Azure DevOps organization.",
  "version": "1.0.0",
  "compatibility": {
    "minPluginVersion": "6.0.0",
    "minProfileSchema": "6.0.0"
  },
  "organization": "CONFIGURE_VIA_INIT_PROFILE",
  "organizationUrl": "https://dev.azure.com/CONFIGURE_VIA_INIT_PROFILE",
  "lastUpdated": "configure-me",

  "projects": [
    {
      "name": "Example Project",
      "id": null,
      "description": "Replace with your project description or run /init profile to auto-populate",
      "aliases": ["example", "ex"],
      "defaultTeam": "Example Project Team",
      "primaryRepo": "example-project",
      "urlPath": "Example%20Project",
      "active": true,
      "priority": 1
    }
  ],

  "contextRules": {
    "persistence": {
      "description": "Context persists throughout conversation session",
      "resetOn": "explicit_switch_or_new_session"
    },
    "detection": {
      "method": "user_activity_analysis",
      "fallback": "ask_user",
      "confirmSelection": true
    },
    "override": {
      "temporary": {
        "triggers": ["in", "for", "from"],
        "behavior": "one_time_query_only"
      },
      "permanent": {
        "triggers": ["switch to", "use", "work on", "change project to", "set project"],
        "behavior": "update_default_context"
      }
    },
    "multiProject": {
      "triggers": ["all projects", "across all projects", "every project", "all my work"],
      "behavior": "query_all_aggregate_results"
    }
  },

  "switchPhrases": {
    "permanent": [
      "switch to {project}",
      "use {project}",
      "work on {project}",
      "change project to {project}",
      "set project {project}",
      "default project {project}"
    ],
    "temporary": [
      "in {project}",
      "for {project}",
      "from {project}",
      "{query} in {project}"
    ],
    "multiProject": [
      "all projects",
      "across all projects",
      "every project",
      "all my work"
    ],
    "queryContext": [
      "what project am I in",
      "current project",
      "which project",
      "show context"
    ]
  },

  "outputFormat": {
    "contextIndicator": " Project: {projectName}",
    "tempOverride": " Querying: {tempProject} (one-time)\n Default: {defaultProject}",
    "multiProject": " Querying all projects...",
    "switchConfirm": "? Switched to {newProject}\n\nPrevious: {oldProject}\nCurrent: {newProject}"
  },

  "urlTemplates": {
    "workItem": "https://dev.azure.com/CONFIGURE_VIA_INIT_PROFILE/{projectUrlPath}/_workitems/edit/{workItemId}",
    "board": "https://dev.azure.com/CONFIGURE_VIA_INIT_PROFILE/{projectUrlPath}/_boards/board",
    "backlog": "https://dev.azure.com/CONFIGURE_VIA_INIT_PROFILE/{projectUrlPath}/_backlogs/backlog",
    "sprint": "https://dev.azure.com/CONFIGURE_VIA_INIT_PROFILE/{projectUrlPath}/_sprints/taskboard",
    "repo": "https://dev.azure.com/CONFIGURE_VIA_INIT_PROFILE/{projectUrlPath}/_git/{repoName}",
    "pr": "https://dev.azure.com/CONFIGURE_VIA_INIT_PROFILE/{projectUrlPath}/_git/{repoName}/pullrequest/{prId}",
    "pipeline": "https://dev.azure.com/CONFIGURE_VIA_INIT_PROFILE/{projectUrlPath}/_build?definitionId={pipelineId}",
    "wiki": "https://dev.azure.com/CONFIGURE_VIA_INIT_PROFILE/{projectUrlPath}/_wiki/wikis"
  },

  "aliasResolution": {
    "description": "Resolve common aliases to project names",
    "caseSensitive": false,
    "matchPartial": true,
    "examples": {
      "example": "Example Project"
    }
  },

  "workTracking": {
    "version": "1.1.0",
    "profileStalenessThresholdDays": 14,
    "stalenessThresholdHours": 4,
    "settings": {
      "minHoursPerDay": 6,
      "workingDaysPerWeek": 5,
      "workingDays": ["Mon", "Tue", "Wed", "Thu", "Fri"],
      "hourTypes": ["task", "meeting", "research", "learning", "review", "admin"],
      "autoPromptOnTaskCompletion": true
    }
  }
}
