# Odoo Docker Environment Variables
# Copy to .env and customize

# =============================================================
# Database (local development defaults)
# =============================================================
POSTGRES_USER=odoo
POSTGRES_PASSWORD=odoo
POSTGRES_DB=postgres

# =============================================================
# Odoo Entrypoint
# =============================================================

# Development mode: auto-reload on file changes
# Set to 1 for development, 0 for production
DEV_MODE=0

# Remote debugger (debugpy on port 5678)
# Set to 1 and expose port 5678 in docker-compose
# Container will WAIT for IDE to attach before starting
ENABLE_DEBUGGER=0

# Wait for database before starting (up to 30s)
WAIT_FOR_DB=0

# Override log level from odoo.conf
# Values: debug, info, warn, error, critical
# Leave empty to use odoo.conf setting
LOG_LEVEL=

# Extra Odoo CLI arguments
# Example: --test-enable --test-tags=my_tag
ODOO_EXTRA_ARGS=

# =============================================================
# Multi-Project Port Allocation
# =============================================================
# Convention: HTTP_PORT + 3 = Gevent, HTTP_PORT + 609 = Debug
#
# Project 1 (default):
# HTTP_PORT=8069
# GEVENT_PORT=8072
# DEBUG_PORT=5678
#
# Project 2:
# HTTP_PORT=8169
# GEVENT_PORT=8172
# DEBUG_PORT=5679

# =============================================================
# Centralized Workspace (for multi-project setups)
# =============================================================
# WORKSPACE_ROOT=/path/to/odoo-docker
# RELIEF_CENTER_HTTP_PORT=8069
# RELIEF_CENTER_GEVENT_PORT=8072
# SOQYA_HTTP_PORT=8169
# SOQYA_GEVENT_PORT=8172
